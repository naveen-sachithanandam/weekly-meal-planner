// Prisma schema for Family Meal Planner V1 (SQLite).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Calendar day of week; week runs Sunday -> Saturday per spec.
enum DayOfWeek {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

/// Meal column in the weekly grid.
enum MealSlotType {
  BREAKFAST
  LUNCH
  DINNER
}

/// Supermarket aisle bucket for grouped shopping views.
enum StoreSection {
  PRODUCE
  DAIRY_AND_EGGS
  DRY_GOODS_AND_GRAINS
  PANTRY_AND_SPICES
  FROZEN
}

/// One saved plan for a Sunday-start week; week identity follows America/Toronto (ET).
model WeeklyPlan {
  /// Stable identifier for this week's plan row.
  id String @id @default(cuid())

  /// Instant for Sunday 00:00 America/Toronto that starts this week; never use a naive UTC midnight that maps to the wrong Toronto calendar Sunday.
  weekStartSunday DateTime

  /// When this plan was first created.
  createdAt DateTime @default(now())

  /// When this plan was last saved (last-write-wins across editors); @default supports raw SQL inserts, @updatedAt refreshes on each update.
  updatedAt DateTime @default(now()) @updatedAt

  days               DayPlan[]
  shoppingLineGroups ShoppingLineGroup[]

  @@unique([weekStartSunday])
}

/// One calendar day within a weekly plan (trip and notes apply to the whole day).
model DayPlan {
  /// Stable identifier for this day row.
  id String @id @default(cuid())

  /// Parent weekly plan this day belongs to.
  weeklyPlanId String

  /// Which day of the week this row represents.
  dayOfWeek DayOfWeek

  /// When true, trip mode hides normal meals and shopping for this entire day.
  isTrip Boolean @default(false)

  /// Optional free text shown with trip mode (destination, constraints).
  tripNotes String?

  weeklyPlan WeeklyPlan @relation(fields: [weeklyPlanId], references: [id], onDelete: Cascade)
  mealSlots  MealSlot[]

  @@unique([weeklyPlanId, dayOfWeek])
}

/// Breakfast, lunch, or dinner cell for one day (names, tags, toddler hints).
model MealSlot {
  /// Stable identifier for this meal slot row.
  id String @id @default(cuid())

  /// Parent day this breakfast/lunch/dinner belongs to.
  dayPlanId String

  /// Which meal column this row is (breakfast, lunch, dinner).
  slot MealSlotType

  /// Unstructured free text for this demo (meal names, notes, inline batch hints; no separate structured recipe fields).
  mainMealText String @default("")

  /// True when protein should show the warning for this slot (or rush breakfast rule applies).
  proteinWarning Boolean @default(false)

  /// True when tagged Quick (under ~15 minutes active time).
  isQuick Boolean @default(false)

  /// True when tagged Make-ahead (night-before friendly).
  isMakeAhead Boolean @default(false)

  /// True when tagged Easy (weekend-friendly tone).
  isEasy Boolean @default(false)

  /// True when tagged Needs time (busy-morning warning context).
  needsTime Boolean @default(false)

  /// True when toddler eats the same as adults without extra grid note.
  toddlerFriendly Boolean @default(false)

  /// Optional toddler line text (e.g. softened) for weekend lunch combined cell.
  toddlerNote String?

  dayPlan                 DayPlan                    @relation(fields: [dayPlanId], references: [id], onDelete: Cascade)
  shoppingContributions   ShoppingLineContribution[]

  @@unique([dayPlanId, slot])
}

/// One consolidated shopping row for aisle + checklist views (shared checked / already-have).
model ShoppingLineGroup {
  /// Stable identifier for this grouped store line.
  id String @id @default(cuid())

  /// Parent week whose shopping list includes this group.
  weeklyPlanId String

  /// Aisle section used to sort View 2 / View 3.
  section StoreSection

  /// Ingredient name shown on the merged line (e.g. Eggs).
  displayName String

  /// Fingerprint so regenerating ingredients can attach contributions to the same group.
  mergeKey String

  /// True when bought today; cleared by weekly clear-checks endpoint.
  checked Boolean @default(false)

  /// True when stocked at home; excluded from "need to buy"; not cleared by clear-checks.
  alreadyHave Boolean @default(false)

  /// Sort position among groups for this week (within section first in UI, then by this value among ties).
  sortOrder Int @default(0)

  weeklyPlan    WeeklyPlan               @relation(fields: [weeklyPlanId], references: [id], onDelete: Cascade)
  contributions ShoppingLineContribution[]

  @@index([weeklyPlanId, mergeKey])
  @@index([weeklyPlanId, section, sortOrder])
}

/// One quantity slice attributed to a meal (View 1) or manual add; rolls into a group for Views 2-3.
model ShoppingLineContribution {
  /// Stable identifier for this contribution row.
  id String @id @default(cuid())

  /// Parent consolidated line carrying checkbox and pantry flags.
  shoppingLineGroupId String

  /// Originating meal slot if auto-generated from the grid; null for manual-only lines.
  mealSlotId String?

  /// Human-readable quantity for this slice (e.g. 4, 4 slices, 2 cups).
  quantityText String @default("")

  /// Normalized unit token so merging only sums compatible rows (null if unknown).
  mergeUnitKey String?

  /// Ordering within a meal's ingredient list in View 1.
  sortOrder Int @default(0)

  shoppingLineGroup ShoppingLineGroup @relation(fields: [shoppingLineGroupId], references: [id], onDelete: Cascade)
  mealSlot          MealSlot?         @relation(fields: [mealSlotId], references: [id], onDelete: SetNull)

  @@index([shoppingLineGroupId])
  @@index([mealSlotId])
}

/// Seed catalog of favourite meals for future AI suggestions (V2).
model FavoriteMeal {
  /// Stable identifier for this favourite row.
  id String @id @default(cuid())

  /// Meal label shown in pick lists.
  name String

  /// Optional coarse cuisine/type label for future filtering.
  category String?

  /// Optional short hints for future suggestion logic (not full recipes).
  notes String?

  @@unique([name])
}
