# Copy to .env.local for local dev (Next.js + npm run db:*)
# Prisma VS Code extension reads `.env` (gitignored) — run:
#   grep '^DATABASE_URL=' .env.local > .env
HOME_TIMEZONE=
# Local dev: http://localhost:11434 — Docker Compose overrides to http://host.docker.internal:11434
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1
# Must match a model from `ollama list` (e.g. llama3.1, mistral). Prefixes like llama3 resolve to llama3.1:latest.
# Pull on the host: ollama pull llama3.1
# Optional — e.g. "South Indian or Maharashtrian"
CUISINE_CONTEXT=
# Optional — household-specific Ollama prompt line (see household-context.mdc)
OLLAMA_HOUSEHOLD_PROMPT=
DATABASE_URL=
